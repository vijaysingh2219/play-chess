{
  "name": "@workspace/payments",
  "version": "1.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./plans": {
      "types": "./dist/plans.d.ts",
      "default": "./dist/plans.js"
    },
    "./products": {
      "types": "./dist/products.d.ts",
      "default": "./dist/products.js"
    },
    "./checkout": {
      "types": "./dist/checkout.d.ts",
      "default": "./dist/checkout.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
      "default": "./dist/webhooks.js"
    },
    "./subscriptions": {
      "types": "./dist/subscriptions.d.ts",
      "default": "./dist/subscriptions.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist generated .turbo node_modules",
    "dev": "tsc --build --watch",
    "lint": "eslint . --max-warnings 0"
  },
  "prettier": "@workspace/prettier-config",
  "dependencies": {
    "@t3-oss/env-nextjs": "catalog:core",
    "@workspace/db": "workspace:*",
    "dotenv": "catalog:core",
    "stripe": "catalog:core",
    "zod": "catalog:core"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/prettier-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "catalog:dev"
  }
}
