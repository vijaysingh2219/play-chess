{
  "name": "@workspace/payments",
  "version": "1.0.0",
  "private": true,
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client.js",
    "./plans": "./dist/plans.js",
    "./products": "./dist/products.js",
    "./checkout": "./dist/checkout.js",
    "./webhooks": "./dist/webhooks.js",
    "./subscriptions": "./dist/subscriptions.js",
    "./types": "./dist/types.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist generated .turbo node_modules",
    "dev": "tsc --build --watch",
    "lint": "eslint . --max-warnings 0"
  },
  "prettier": "@workspace/prettier-config",
  "dependencies": {
    "@t3-oss/env-nextjs": "catalog:core",
    "@workspace/db": "workspace:*",
    "dotenv": "catalog:core",
    "stripe": "catalog:core",
    "zod": "catalog:core"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/prettier-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "catalog:dev"
  }
}
