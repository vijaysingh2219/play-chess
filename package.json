{
  "name": "play-chess",
  "version": "1.0.0",
  "description": "Full-stack application with Next.js frontend, Express backend, authentication and PostgreSQL database",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean",
    "dev": "turbo dev",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up --build",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "turbo check-types",
    "start": "turbo start",
    "test": "turbo test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "catalog:eslint",
    "husky": "catalog:dev",
    "lint-staged": "catalog:dev",
    "prettier": "catalog:prettier",
    "prettier-plugin-organize-imports": "catalog:prettier",
    "prettier-plugin-packagejson": "catalog:prettier",
    "prettier-plugin-tailwindcss": "catalog:prettier",
    "turbo": "catalog:core",
    "typescript": "catalog:dev"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  }
}
