{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "15",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "db:generate",
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "generated/**/*"
      ],
      "env": [
        "DATABASE_URL"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^build"
      ]
    },
    "clean": {
      "cache": false
    },
    "db:deploy": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "dependsOn": [
        "^db:generate"
      ],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXT_PUBLIC_BASE_URL",
        "NODE_ENV",
        "PORT",
        "ALLOWED_ORIGINS",
        "BETTER_AUTH_URL",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_PRICE_ID_PRO_MONTHLY",
        "STRIPE_PRICE_ID_PRO_YEARLY",
        "RESEND_TOKEN",
        "RESEND_EMAIL_FROM",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "REDIS_URL",
        "REDIS_HOST",
        "REDIS_PORT"
      ]
    },
    "start": {
      "cache": false
    },
    "test": {
      "outputs": [
        "coverage/**"
      ],
      "dependsOn": []
    }
  }
}
